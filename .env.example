# Project-level env consumed by docker-compose (NOT the Laravel app .env,
# which lives at fogospt/.env). Copy this file to .env and adjust.
#
# Used to run the PHP-FPM container as the host user so writes to
# storage/ and bootstrap/cache don't end up owned by root or www-data.
# Get yours with: `id -u` and `id -g`.
UID=1000
GID=1000
